# Скопируйте в корень репозитория как `.env` и заполните значения.
# Реальный `.env` в git не коммитится.

# WordPress REST API (scripts/wp-create-pages.py, wp-assign-cat-templates.py, wp-api-setup.sh)
WP_BASE_URL=https://staging.example.com
WP_USER=
WP_APP_PASSWORD=

# WooCommerce REST (wp-api-setup.sh)
Woo_Klucz_konsumenta=
Woo_Tajny_konsumenta=

# SSH CyberFolks (deploy-rsync.sh, staging-*.sh, upload_prod_ui_files.py)
cyberfolks_ssh_host=
cyberfolks_ssh_port=22
cyberfolks_ssh_user=
cyberfolks_ssh_password=

# Prod path on server (deploy-rsync.sh prod, upload_prod_ui_files.py)
# STAGING_PROD_PATH=domains/mnsk7-tools.pl/public_html
# STAGING_REMOTE_PATH=domains/mnsk7-tools.pl/public_html/staging

# BaseLinker (baselinker_sync_products.py, push_title_params_to_baselinker.py)
BASELINKER_API_TOKEN=
BASELINKER_INVENTORY_ID=
BASELINKER_LANGUAGE=pl
BASELINKER_PRICE_GROUP_ID=
BASELINKER_WAREHOUSE_ID=
