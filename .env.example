# Скопируйте в корень репозитория как `.env` и заполните значения.
# Реальный `.env` в git не коммитится.

# WordPress REST API (scripts/wp-create-pages.py, wp-assign-cat-templates.py, wp-api-setup.sh)
WP_BASE_URL=https://staging.example.com
WP_USER=
WP_APP_PASSWORD=

# Google Analytics 4 Measurement Protocol (set the real value only in production config)
GA4_MEASUREMENT_PROTOCOL_API_SECRET=

# WooCommerce REST (wp-api-setup.sh)
Woo_Klucz_konsumenta=
Woo_Tajny_konsumenta=

# SSH CyberFolks (legacy) or dhosting (new_server_* — preferred for prod)
cyberfolks_ssh_host=
cyberfolks_ssh_port=22
cyberfolks_ssh_user=
cyberfolks_ssh_password=

new_server_ssh_host=
new_server_ssh_port=22
new_server_ssh_user=
new_server_ssh_password=
NEW_SERVER_WP_PATH=mnsk7-tools.pl/public_html

# Prod path on server (deploy-rsync.sh prod, deploy_prod_sftp.py)
# STAGING_PROD_PATH=mnsk7-tools.pl/public_html
# STAGING_REMOTE_PATH=domains/mnsk7-tools.pl/public_html/staging

# GitHub Actions prod deploy — set as repository secrets (not in .env):
# PROD_SSH_HOST, PROD_SSH_PORT, PROD_SSH_USER, PROD_SSH_PASSWORD, PROD_REMOTE_PATH

# Break-glass manual prod deploy (local scripts only):
# ALLOW_MANUAL_PROD_DEPLOY=1

# BaseLinker (baselinker_sync_products.py, push_title_params_to_baselinker.py)
BASELINKER_API_TOKEN=
BASELINKER_INVENTORY_ID=19398
BASELINKER_LANGUAGE=pl
BASELINKER_PRICE_GROUP_ID=
BASELINKER_WAREHOUSE_ID=
