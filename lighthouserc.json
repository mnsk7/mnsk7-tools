{
  "ci": {
    "collect": {
      "numberOfRuns": 2,
      "url": [
        "https://staging.mnsk7-tools.pl/",
        "https://staging.mnsk7-tools.pl/sklep/",
        "https://staging.mnsk7-tools.pl/koszyk/",
        "https://staging.mnsk7-tools.pl/zamowienie/"
      ],
      "settings": {
        "preset": "desktop"
      }
    },
    "assert": {
      "assertions": {
        "categories:performance": ["warn", { "minScore": 0.8 }],
        "categories:accessibility": ["warn", { "minScore": 0.9 }],
        "categories:seo": ["error", { "minScore": 0.9 }]
      }
    },
    "upload": {
      "target": "temporary-public-storage"
    }
  }
}

